# Copy this file to .env and fill in the keys you want to use.

# OpenAI is used first when configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Gemini is used when OpenAI is not configured.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional upload limit for local MVP.
MAX_UPLOAD_MB=100

# Optional public sales/contact copy shown on the paid trial form.
PUBLIC_CONTACT=
PUBLIC_PAYMENT_NOTE=
